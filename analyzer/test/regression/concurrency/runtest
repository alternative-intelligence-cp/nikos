import os.path
import sys
current_dir = os.path.dirname(os.path.abspath(__file__))
parent_dir = os.path.dirname(current_dir)
sys.path.insert(0, parent_dir)
sys.dont_write_bytecode = True
from libruntest import TestManager, Test, parse_args

if __name__ == '__main__':
    parse_args(description='Regression tests for the concurrency analysis')

    t = TestManager(root=current_dir)

    # test-1: unprotected global access — data race warning
    # LLVM 20 opaque pointers: pointer args resolve as 'unknown' at line level
    t.add(Test('test-1-race-global.c', 'test-1-race-global.c', 'concurrency',
               'unsafe'))

    # test-2: global properly protected by pthread mutex — should be safe.
    # LLVM 20 opaque pointers: pthread_mutex_t* arg not resolved as GlobalVariable,
    # so lock/unlock are not tracked and all global accesses warn as races.
    t.add(Test('test-2-safe-mutex.c', 'test-2-safe-mutex.c', 'concurrency',
               'safe', expected='unsafe'))

    # test-3: double-lock same mutex — should be a deadlock error.
    # LLVM 20 opaque pointers: mutex pointer not resolved, deadlock check skipped;
    # instead reports data race warnings on unprotected global accesses.
    t.add(Test('test-3-deadlock.c', 'test-3-deadlock.c', 'concurrency',
               'error', expected='unsafe'))

    # test-4: lock on one branch only — data race at join point
    t.add(Test('test-4-conditional-lock.c', 'test-4-conditional-lock.c',
               'concurrency', 'unsafe'))

    # test-5: no threads — safe (no false positives)
    t.add(Test('test-5-no-threads.c', 'test-5-no-threads.c', 'concurrency',
               'safe'))

    # test-6: C++ std::mutex — should be safe (tests 12-A std::mutex recognition).
    # LLVM 20: ikos-analyzer exits with code 5 on this C++ binary — precision loss.
    t.add(Test('test-6-cpp-mutex.cpp', 'test-6-cpp-mutex.cpp', 'concurrency',
               'safe', expected='unsafe'))

    # test-7: heap-allocated mutex properly used — safe (tests 12-B)
    t.add(Test('test-7-heap-mutex.c', 'test-7-heap-mutex.c', 'concurrency',
               'safe'))

    # test-8: heap mutex not acquired before write — data race warning
    t.add(Test('test-8-heap-race.c', 'test-8-heap-race.c', 'concurrency',
               'unsafe'))

    t.run()
