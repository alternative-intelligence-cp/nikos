import os.path
import sys
current_dir = os.path.dirname(os.path.abspath(__file__))
parent_dir = os.path.dirname(current_dir)
sys.path.insert(0, parent_dir)
sys.dont_write_bytecode = True
from libruntest import TestManager, Test, parse_args

if __name__ == '__main__':
    parse_args(description='Regression tests for the use-after-free analysis')

    t = TestManager(root=current_dir)

    # test-1: heap read after free — definite error
    t.add(Test('test-1-uaf-read.c', 'test-1-uaf-read.c', 'uaf', 'error',
               line_checks=[(10, 'error')]))

    # test-2: heap write after free — definite error
    t.add(Test('test-2-uaf-write.c', 'test-2-uaf-write.c', 'uaf', 'error',
               line_checks=[(9, 'error')]))

    # test-3: conditional free before read — possible UAF (warning or error)
    t.add(Test('test-3-uaf-conditional.c', 'test-3-uaf-conditional.c', 'uaf',
               'unsafe', line_checks=[(16, 'error', 'warning')]))

    # test-4: correct allocation/use/free order — must be fully safe
    t.add(Test('test-4-uaf-safe.c', 'test-4-uaf-safe.c', 'uaf', 'safe'))

    # test-5: array element access after free — definite error
    t.add(Test('test-5-uaf-array.c', 'test-5-uaf-array.c', 'uaf', 'error',
               line_checks=[(18, 'error')]))

    # test-6: use-after-return — definite error
    t.add(Test('test-6-uar.c', 'test-6-uar.c', 'uaf', 'error',
               line_checks=[(12, 'error')]))

    # test-7: null guard after free does NOT prevent UAF — definite error
    t.add(Test('test-7-uaf-null-guarded.c', 'test-7-uaf-null-guarded.c', 'uaf',
               'error', line_checks=[(15, 'error')]))

    # test-8: free inside loop but last pointer not freed — safe
    t.add(Test('test-8-uaf-loop.c', 'test-8-uaf-loop.c', 'uaf', 'safe'))

    t.run()
