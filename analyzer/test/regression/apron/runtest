import os
import sys

root = os.path.dirname(os.path.realpath(__file__))
sys.path.insert(0, os.path.join(root, '..'))
import libruntest

libruntest.parse_args(description='Tests for APRON abstract domain integration')

t = libruntest.TestManager(root)

# =========================================================================
# BOA (Buffer Overflow Analysis) with APRON octagon domain
# =========================================================================

# Safe: simple loop with constant bound — apron-octagon smoke test
t.add(libruntest.Test(
    'test-apron-1.c',
    'test-apron-1.c (apron-octagon, safe loop)',
    'boa', 'safe',
    domain='apron-octagon'))

# Error: out-of-bounds at index 10 — apron-octagon detects it
t.add(libruntest.Test(
    'test-apron-1-unsafe.c',
    'test-apron-1-unsafe.c (apron-octagon, buf[10] OOB)',
    'boa', 'error',
    domain='apron-octagon',
    line_checks=[(16, 'error')]))

# Safe: interprocedural loop with var-pack-apron-octagon
t.add(libruntest.Test(
    'test-apron-2.c',
    'test-apron-2.c (var-pack-apron-octagon, interprocedural)',
    'boa', 'safe',
    domain='var-pack-apron-octagon'))

# =========================================================================
# Nullity analysis with APRON octagon domain
# =========================================================================

# Error: unconditional null dereference — apron-octagon nullity analysis
t.add(libruntest.Test(
    'test-apron-3.c',
    'test-apron-3.c (apron-octagon, null deref)',
    'nullity', 'error',
    domain='apron-octagon',
    line_checks=[(13, 'error')]))

t.run()
