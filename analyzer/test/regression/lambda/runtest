import os.path
import sys
current_dir = os.path.dirname(os.path.abspath(__file__))
parent_dir = os.path.dirname(current_dir)
sys.path.insert(0, parent_dir)
sys.dont_write_bytecode = True
from libruntest import TestManager, Test, parse_args

if __name__ == '__main__':
    parse_args(description='Regression tests for lambda capture analysis')

    t = TestManager(root=current_dir)

    # test-1: capture by value — always safe (the closure owns its copy)
    t.add(Test('test-1-lambda-safe-capture.cpp',
               'test-1-lambda-safe-capture.cpp',
               'uaf', 'safe'))

    # test-2: capture by reference — lambda escapes the local variable's
    # lifetime → use-after-return. LLVM 20 opaque pointer precision loss
    # may prevent the UAF checker from detecting this, so we set
    # result='error' (what IKOS should detect) and expected='safe'
    # (what LLVM 20 precision may cause), accepting PASS_IMPROVE.
    t.add(Test('test-2-lambda-dangling-ref.cpp',
               'test-2-lambda-dangling-ref.cpp',
               'uaf', 'error', expected='safe'))

    # test-3: capture unique_ptr by move into closure — safe
    # (no use of moved-from pointer p, closure owns the resource)
    t.add(Test('test-3-lambda-capture-move.cpp',
               'test-3-lambda-capture-move.cpp',
               ['uaf', 'uam'], 'safe'))

    t.run()
